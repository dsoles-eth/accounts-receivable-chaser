# ============================================================
# Accounts Receivable Chaser — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── Email sending ─────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password_here

# ── Your identity (appears in email footers) ──────────────────
YOUR_NAME=Your Name
YOUR_COMPANY=Your Company LLC

# ── Invoice data path ─────────────────────────────────────────
INVOICES_CSV=data/invoices.csv

# ── Sent log path (tracks which emails have been sent) ────────
SENT_LOG=data/sent_log.json

# ── Notification channel (discord or telegram) ────────────────
NOTIFY_CHANNEL=discord
DISCORD_CHANNEL_ID=your_channel_id
# TELEGRAM_CHAT_ID=your_telegram_chat_id

# ── Dry run mode ──────────────────────────────────────────────
# true = log what would be sent, but don't actually send emails
# Set to false when you're ready to go live
DRY_RUN=true
